# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/booking_system

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
# For local dev use Mailtrap (https://mailtrap.io) — free, catches all outgoing mail
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM_EMAIL=noreply@bookmyticket.com

# ── Client ─────────────────────────────────────────────────────────────────────
# Used to build verification/reset links sent in emails
CLIENT_URL=http://localhost:3000
